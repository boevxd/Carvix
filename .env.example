PORT=3000

# ───────────────────────────────────────────────────────────
# PostgreSQL
# ───────────────────────────────────────────────────────────
# Вариант 1: одна строка подключения (используется в продакшене / Render)
# DATABASE_URL=postgres://user:password@host:5432/carvix

# Вариант 2: отдельные поля (удобно для локальной разработки)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=carvix

# ───────────────────────────────────────────────────────────
# JWT
# ───────────────────────────────────────────────────────────
JWT_SECRET=замените_на_длинную_случайную_строку
JWT_EXPIRES_IN=7d

# production | development
NODE_ENV=development
