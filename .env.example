PORT=3000

# ───────────────────────────────────────────────────────────
# PostgreSQL
# ───────────────────────────────────────────────────────────
# Вариант 1: одна строка подключения (используется в продакшене / Render)
# DATABASE_URL=postgres://user:password@host:5432/carvix

# Вариант 2: отдельные поля (удобно для локальной разработки)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=carvix

# ───────────────────────────────────────────────────────────
# JWT
# ───────────────────────────────────────────────────────────
JWT_SECRET=замените_на_длинную_случайную_строку
JWT_EXPIRES_IN=7d

# production | development
NODE_ENV=development

# ───────────────────────────────────────────────────────────
# SMTP — отправка отчётов на email (опционально).
# Если не задано, кнопка «Отправить на email» вернёт 503 и фронт
# автоматически переключится на скачивание файла.
#
# Пример для Gmail (нужен App Password):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxx_xxxx_xxxx_xxxx
#   SMTP_FROM=Carvix <you@gmail.com>
#
# Пример для Yandex:
#   SMTP_HOST=smtp.yandex.ru
#   SMTP_PORT=465
#   SMTP_SECURE=true
# ───────────────────────────────────────────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
